# ============================================
# AVSN WhatsApp Bot - Configuração
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- Evolution API ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=avsn-bot

# --- Perplexity API ---
# Obtenha em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Servidor do Bot ---
BOT_PORT=3000
BOT_WEBHOOK_PATH=/webhook/evolution

# --- Controle de Acesso ---
# Números autorizados (separados por vírgula, com DDI+DDD, sem +)
# Ex: 5511999998888,5516999997777
AUTHORIZED_NUMBERS=

# --- Log ---
LOG_LEVEL=info
